# PostgreSQL (docker compose db service)
POSTGRES_USER=bastion
POSTGRES_PASSWORD=bastion
POSTGRES_DB=bastion

# API database URL — use host `db` inside compose; use `localhost` for local go run against compose db.
DATABASE_URL=postgres://bastion:bastion@db:5432/bastion?sslmode=disable

# API listen address (container listens on 8080)
API_ADDR=:8080

# Host port published for the api service
API_PORT=8080

# Allowed browser origin for local SPA dev (Vite default)
CORS_ORIGIN=http://localhost:5173

# Static SPA root for the API (local go run from repo root; compose sets /web/dist in docker-compose.yml)
WEB_DIST=web/dist

# Frontend dev: optional API base URL when not using Vite proxy (see web/.env.example)
# VITE_API_URL=http://localhost:8080

# JWT auth (required when DATABASE_URL is set)
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-use-openssl-rand-base64-32
# Token lifetime (default 24h); accepts Go duration strings e.g. 1h, 72h
JWT_TTL=24h
